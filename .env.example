# Server
PORT=3000

# Optional: OpenAI API key for AI-powered replies. If not set, replies echo the message.
# OPENAI_API_KEY=sk-...

# Optional: Model for chat completions (default: gpt-3.5-turbo)
# OPENAI_MODEL=gpt-3.5-turbo

# Optional: When set, POST /chat requires header x-chat-assistant-key to match (for ai-chat-assistant)
CHAT_ASSISTANT_KEY=1234567890

# Optional: Chat bot base URL for ai-chat-assistant client (used by the client, not by this server)
CHAT_BOT_URL=http://localhost:4000
